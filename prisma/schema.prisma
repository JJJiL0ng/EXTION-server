generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  email        String?  @unique
  displayName  String
  photoURL     String?
  isGuest      Boolean  @default(false)
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @updatedAt
  preferences  Json? // UI 설정, 기본값 등
  statistics   Json? // 사용 통계

  // 관계
  spreadSheets SpreadSheet[]
  chats        Chat[]

  @@index([createdAt])
}

// 메인 스프레드시트 모델 (메타데이터 관리)
model SpreadSheet {
  id         String            @id @default(cuid())
  fileName   String
  fileSize   Int? // 바이트 단위 (메타데이터로 유지, 실제 JSON 크기와 다를 수 있음)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  lastOpened DateTime          @default(now()) // 최근 열어본 시간
  version    Int               @default(1) // 파일 버전 (낙관적 잠금을 위한 핵심 필드)
  status     SpreadSheetStatus @default(ACTIVE)

  // 외래키
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatId String // 스프레드시트에 연결된 기본 채팅 ID (옵션)

  // 관계: 스프레드시트 데이터와 1:1 관계 유지
  data        SpreadSheetData?
  chats       Chat[]

  @@unique([userId, id]) // 사용자별 스프레드시트 ID 고유
  @@index([userId, updatedAt])
  @@index([userId, lastOpened])
}

// 스프레드시트 데이터 저장 (압축되지 않은 JSONB)
// 이제 전체 스프레드시트의 JSON 데이터를 압축 없이 그대로 저장합니다.
model SpreadSheetData {
  id            String   @id @default(cuid())
  spreadSheetId String   @unique
  data          Json     @db.JsonB // 압축되지 않은 전체 스프레드시트 JSON 데이터
  sheetCount    Int      @default(1) // 포함된 시트 수
  savedAt       DateTime @default(now())

  // 관계
  spreadSheet SpreadSheet @relation(fields: [spreadSheetId], references: [id], onDelete: Cascade)

  @@index([savedAt])
}

// 편집 히스토리 (단순화된 세션 관리)
// 개별 델타 기록이 사라지므로, 세션 단위의 변경 메타데이터만 남습니다.

// 채팅 (AI 대화)
model Chat {
  id           String     @id @default(cuid())
  title        String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  messageCount Int        @default(0)
  status       ChatStatus @default(ACTIVE)

  // 스프레드시트 연결 (옵션)
  spreadSheetId String?
  spreadSheet   SpreadSheet? @relation(fields: [spreadSheetId], references: [id], onDelete: Cascade)

  // 사용자 연결
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 관계
  messages Message[]

  @@index([userId, status, updatedAt])
  @@index([spreadSheetId, updatedAt])
}

// 메시지
model Message {
  id        String      @id @default(cuid())
  content   String      @db.Text // 긴 텍스트 지원
  createdAt DateTime    @default(now())
  role      MessageRole
  type      MessageType @default(TEXT)

  // AI 답변 메타데이터(aiChatRes) (JSONB로 변경)
  aiChatRes Json? @db.JsonB // AI 응답 전체 데이터, 토큰 수, 처리 시간, 캐시 여부 등

  // 관계
  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
  @@index([aiChatRes], type: Gin) // JSONB 검색을 위한 GIN 인덱스
}

// Enum 정의
enum SpreadSheetStatus {
  ACTIVE // 활성 상태
  ARCHIVED // 보관됨
  DELETED // 삭제됨 (소프트 삭제)
}


enum ChatStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MessageType {
  TEXT // 일반 텍스트
  ANALYSIS // 데이터 분석 결과
  SUGGESTION // AI 제안
  ERROR // 오류 메시지
}
