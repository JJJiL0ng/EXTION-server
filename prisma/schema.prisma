generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id
  email         String?         @unique
  displayName   String
  photoURL      String?
  isGuest       Boolean         @default(false)
  createdAt     DateTime        @default(now())
  lastActiveAt  DateTime        @updatedAt
  preferences   Json?
  statistics    Json?
  chats         Chat[]
  sheetMetaData SheetMetaData[]
}

model SheetMetaData {
  id               String           @id @default(cuid())
  fileName         String
  originalFileName String?
  fileSize         Int?
  fileType         String?
  activeSheetIndex Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  userId           String
  chats            Chat[]
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sheetTableData   SheetTableData[]
}

model SheetTableData {
  id              String        @id @default(cuid())
  name            String
  index           Int
  data            Json
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sheetMetaDataId String
  sheetMetaData   SheetMetaData @relation(fields: [sheetMetaDataId], references: [id], onDelete: Cascade)

  @@unique([sheetMetaDataId, index])
  @@unique([sheetMetaDataId, name])
}

model Chat {
  id              String         @id @default(cuid())
  title           String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  messageCount    Int            @default(0)
  status          ChatStatus     @default(ACTIVE)
  analytics       Json?
  userId          String
  sheetMetaDataId String?
  sheetMetaData   SheetMetaData? @relation(fields: [sheetMetaDataId], references: [id])
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        Message[]
}

model Message {
  id             String       @id @default(cuid())
  content        String
  timestamp      DateTime     @default(now())
  role           MessageRole
  type           MessageType
  mode           MessageMode?
  sheetContext   Json?
  formulaData    Json?
  artifactData   Json?
  dataChangeInfo Json?
  fileUploadInfo Json?
  chatId         String
  metadata       Json?
  chat           Chat         @relation(fields: [chatId], references: [id], onDelete: Cascade)
}

enum ChatStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum MessageRole {
  USER
  EXTION_AI
  SYSTEM
}

enum MessageType {
  TEXT
  FILE_UPLOAD
  FORMULA
  VISUALIZATION
  DATA_GENERATION
  FUNCTION
  DATA_EDIT
}

enum MessageMode {
  NORMAL
  FORMULA
  VISUALIZATION
  DATA_GENERATION
  DATA_FIX
  DATA_EDIT
  FUNCTION
}
