// /prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  email        String?  @unique
  displayName  String
  photoURL     String?
  isGuest      Boolean  @default(false)
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @updatedAt
  preferences  Json?    // UI 설정, 기본값 등
  statistics   Json?    // 사용 통계

  // 관계
  spreadSheets SpreadSheet[]
  chats        Chat[]

  @@index([createdAt])
}

// 메인 스프레드시트 모델 (메타데이터 관리)
model SpreadSheet {
  id             String   @id @default(cuid())
  fileName       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastOpened     DateTime @default(now())
  status         SpreadSheetStatus @default(ACTIVE)
  
  // ⭐️ 변경점: 낙관적 잠금용 필드 이름 명확화
  editLockVersion Int      @default(1) // Optimistic Locking을 위한 버전

  // ⭐️ 추가: 최신 버전을 가리키는 필드
  latestVersion  Int      @default(1) // 히스토리 관리를 위한 최신 버전 번호

  // 외래키
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatId         String?  // 스프레드시트에 연결된 기본 채팅 ID

  // ⭐️ 변경점: 관계를 1:N으로 변경
  spreadSheetVersions      SpreadSheetVersionData[]
  chats          Chat[]
 
  @@unique([userId, id])
  @@index([userId, updatedAt])
  @@index([userId, lastOpened])
}

// 이제 각 버전의 데이터 스냅샷을 저장합니다.
model SpreadSheetVersionData {
  id            String   @id @default(cuid())
  
  // ⭐️ 변경점: 더 이상 unique가 아님
  spreadSheetId String
  
  // ⭐️ 추가: 버전 정보
  spreadSheetVersionNumber Int      // 해당 스프레드시트 내에서의 버전 번호 (e.g., 1, 2, 3...)
  name          String?  // 사용자가 버전에 붙이는 이름 (e.g., "1분기 마감", "초안")
  
  // 데이터
  data          Json     @db.JsonB // 압축되지 않은 전체 스프레드시트 JSON 데이터
  sheetCount    Int      @default(1)
  fileSize      Int?     // 이 버전의 데이터 크기
  savedAt       DateTime @default(now())

  // 관계
  spreadSheet SpreadSheet @relation(fields: [spreadSheetId], references: [id], onDelete: Cascade)

  // ⭐️ 추가: 특정 스프레드시트 내에서 버전 번호는 고유해야 함
  @@unique([spreadSheetId, spreadSheetVersionNumber])
  @@index([savedAt])
}

// (Chat, Message 및 Enum 모델은 변경 없음)
model Chat {
  id            String     @id @default(cuid())
  title         String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  messageCount  Int        @default(0)
  status        ChatStatus @default(ACTIVE)
  spreadSheetId String?
  spreadSheet   SpreadSheet? @relation(fields: [spreadSheetId], references: [id], onDelete: Cascade)
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      Message[]
  @@index([userId, status, updatedAt])
  @@index([spreadSheetId, updatedAt])
}

model Message {
  id        String      @id @default(cuid())
  content   String      @db.Text
  createdAt DateTime    @default(now())
  role      MessageRole
  type      MessageType @default(TEXT)
  aiChatRes Json?       @db.JsonB
  chatId    String
  chat      Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  @@index([chatId, createdAt])
  @@index([aiChatRes], type: Gin)
}

enum SpreadSheetStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum ChatStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MessageType {
  TEXT
  ANALYSIS
  SUGGESTION
  ERROR
}