// /prisma/schema.prisma

// =================================================================================
// 최종 아키텍처 요약
//
// 1. Spreadsheet Versioning:
//    - 'SpreadSheetVersionData'는 Git의 커밋처럼 동작합니다.
//    - 'parentId'를 통해 버전 간의 트리 구조(계보)를 형성합니다.
//    - 'headVersionId'는 현재 활성화된 버전을 가리키는 포인터입니다.
//
// 2. Chat Architecture (3-Layer):
//    - Chat (1:1 컨테이너): 스프레드시트와 1:1로 매칭되는 안정적인 ID 컨테이너입니다.
//    - ChatSession (사용자 인지 대화): 사용자가 명시적으로 생성하는 대화 스트림입니다. (커서 UX 리스트 항목)
//    - ChatSessionBranch (내부 버전 단위): 롤백 시 히스토리를 재구성하는, 1메시지=1브랜치의 원자적 단위입니다.
//
// 3. Invite Code System (Closed Beta):
//    - InviteCode: 어드민이 생성하는 초대 코드
//    - User.inviteCodeId: 유저가 사용한 초대 코드 추적
//    - 1 초대 코드 = 1 유저 (일대일 매핑)
// =================================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =================================
// Invite Code (Closed Beta)
// =================================

model InviteCode {
  id        String   @id @default(cuid())
  code      String   @unique // "EXTION-USER-001" 형식 또는 자유 형식
  createdAt DateTime @default(now())
  createdBy String? // 어드민 유저 ID (선택)

  // ⭐️ 사용 여부 추적
  isUsed Boolean   @default(false)
  usedAt DateTime?

  // ⭐️ 메모 (어드민용)
  note String? // "김철수 - 쿠팡 셀러" 같은 메모

  // ⭐️ 관계: 1 초대 코드 = 1 유저
  user User? @relation("InviteCodeToUser")

  @@index([code])
  @@index([isUsed])
}

model User {
  id           String   @id
  email        String?  @unique
  displayName  String
  photoURL     String?
  isGuest      Boolean  @default(false)
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @updatedAt
  preferences  Json?
  statistics   Json?

  // ⭐️ 초대 코드 관계 추가
  inviteCodeId String?     @unique // 1:1 관계를 위한 unique
  inviteCode   InviteCode? @relation("InviteCodeToUser", fields: [inviteCodeId], references: [id], onDelete: SetNull)

  // 관계
  spreadSheets             SpreadSheet[]
  chats                    Chat[]
  versionsAuthored         SpreadSheetVersionData[] // 사용자가 생성한 모든 버전을 추적하기 위한 관계
  schemaConverterWorkflows SchemaConverterWorkflow[] @relation("UserWorkflows")

  @@index([inviteCodeId])
}

// =================================
// Spreadsheet & Versioning
// =================================

model SpreadSheet {
  id              String            @id @default(cuid())
  fileName        String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  lastOpened      DateTime          @default(now())
  status          SpreadSheetStatus @default(ACTIVE)
  editLockVersion Int               @default(1)

  // ⭐️ 작동 방식:
  // 사용자가 이 시트를 열 때, 이 ID에 해당하는 'SpreadSheetVersionData'를 찾아서 보여줍니다.
  // 롤백과 분기가 일어나면 이 포인터가 새로운 최신 버전을 가리키도록 업데이트됩니다.
  headVersionId String?

  userId   String
  user     User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions SpreadSheetVersionData[]

  // ⭐️ 사용 방법:
  // 스프레드시트와 채팅은 항상 1:1 관계를 유지합니다.
  // 채팅 관련 기능을 호출할 때 `spreadSheet.chat.id`를 사용합니다.
  chat Chat?
}

model SpreadSheetVersionData {
  id            String      @id @default(cuid())
  spreadSheetId String
  spreadSheet   SpreadSheet @relation(fields: [spreadSheetId], references: [id], onDelete: Cascade)

  // ⭐️ 작동 방식:
  // Git의 커밋처럼, 이 버전이 어떤 부모 버전에서 파생되었는지 가리킵니다.
  // 이 필드를 재귀적으로 따라가면 버전의 전체 히스토리를 재구성할 수 있습니다.
  // 최초 버전은 이 값이 null입니다.
  parentId String?

  // ⭐️ 사용 방법:
  // 누가 이 버전을 만들었는지 기록하여 기여자를 추적하거나 권한을 관리하는 데 사용합니다.
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: NoAction)

  name    String?
  data    Json     @db.JsonB
  savedAt DateTime @default(now())

  // ⭐️ 변경점: 이제 ChatSessionBranch 와의 관계를 가집니다.
  branches ChatSessionBranch[]
}

// =================================
// Chat Architecture (3-Layer)
// =================================

// 1단계: Chat (안정적인 1:1 컨테이너)
model Chat {
  id    String  @id @default(cuid())
  title String?

  // ⭐️ 사용 방법:
  // 프론트엔드는 스프레드시트를 여는 순간 이 `chatId`를 받아두고,
  // 이후 모든 채팅 관련 API 호출에 이 ID를 계속 사용합니다.
  // 이 ID는 절대 변하지 않으므로 프론트엔드 로직이 단순해집니다.
  spreadSheetId String      @unique
  spreadSheet   SpreadSheet @relation(fields: [spreadSheetId], references: [id], onDelete: Cascade)

  // ⭐️ 작동 방식:
  // 이 Chat 컨테이너에 속한 여러 대화 스트림(`ChatSession`) 중,
  // 현재 사용자가 보고 있거나 이어가고 있는 활성 세션을 가리키는 포인터입니다.
  // 사용자가 '새 대화 시작'을 하거나 다른 대화를 선택하면 이 포인터가 업데이트됩니다.
  latestChatSessionId String?

  userId   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions ChatSession[]

  status       ChatStatus @default(ACTIVE)
  messageCount Int        @default(0)
}

// 2단계: ChatSession (사용자가 인지하는 대화 스트림)
model ChatSession {
  id String @id @default(cuid())

  // ⭐️ 사용 방법:
  // '커서 UX'의 리스트에 표시될 대화의 이름입니다.
  // 사용자가 "새 대화 시작"을 할 때 이름을 붙이거나, 시스템이 자동으로 생성할 수 있습니다.
  name      String?
  createdAt DateTime @default(now())

  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  // ⭐️ 작동 방식:
  // 이 대화 스트림 내부에서, 롤백 등으로 인해 재구성된 히스토리 중
  // 가장 최신 버전(`ChatSessionBranch`)이 무엇인지를 가리키는 포인터입니다.
  latestBranchId String?

  // ⭐️ 사용 방법:
  // 어드민 툴 등에서 이 세션이 어떤 다른 세션에서 파생되었는지 추적하는 데 사용할 수 있습니다.
  parentSessionId String?

  // ⭐️ 작동 방식:
  // 이 세션이 어떤 시트 버전을 기준으로 시작되었는지 기록합니다.
  forkedFromSpreadSheetVersionId String?

  branches ChatSessionBranch[]

  @@index([chatId])
}

// 3단계: ChatSessionBranch (내부 버전 관리 단위)
model ChatSessionBranch {
  id            String      @id @default(cuid())
  chatSessionId String
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  // ⭐️ 작동 방식:
  // '1메시지 = 1브랜치' 원칙의 핵심.
  // 롤백이 일어나면, 새로운 브랜치가 롤백 대상의 부모 브랜치를 가리키게 됩니다.
  // 이 체인을 따라가면 사용자에게 보여줄 선형적인 히스토리가 재구성됩니다.
  parentBranchId String?

  messages Message[]

  // ⭐️ 변경점: spreadSheetVersionId 를 Message 에서 이곳으로 이동했습니다.
  // 이 브랜치(상호작용)의 결과로 생성된 스프레드시트 버전을 가리킵니다.
  // 시트 변경이 없었다면 null이 됩니다.
  spreadSheetVersionId String?
  spreadSheetVersion   SpreadSheetVersionData? @relation(fields: [spreadSheetVersionId], references: [id], onDelete: SetNull)

  @@index([chatSessionId])
  @@index([spreadSheetVersionId])
}

// Message는 최종적으로 가장 작은 단위인 ChatSessionBranch에 속합니다.
model Message {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())

  // ⭐️ 변경점: 메시지는 이제 특정 브랜치에 소속됩니다.
  chatSessionBranchId String
  chatSessionBranch   ChatSessionBranch @relation(fields: [chatSessionBranchId], references: [id], onDelete: Cascade)

  // ⭐️ 변경점: spreadSheetVersionId 관련 필드들이 삭제되었습니다.

  role      MessageRole
  type      MessageType @default(TEXT)
  aiChatRes Json?       @db.JsonB
}

// =================================
// Schema Converter Feature
// =================================

// 1. 최상위 워크플로우 컨테이너
model SchemaConverterWorkflow {
  id          String   @id @default(cuid())
  name        String? // 워크플로우 이름 (예: "쿠팡 → 스마트스토어 변환")
  description String? // 설명
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation("UserWorkflows", fields: [userId], references: [id], onDelete: Cascade)

  // 하위 관계들
  sourceSheetVersions SourceSheetVersion[]
  targetSheetVersions TargetSheetVersion[]
  workflowCodes       WorkflowCode[]
  appliedSheets       AppliedConvertingSheet[]

  @@index([userId])
}

// 2. 소스 시트 버전 (입력 데이터)
model SourceSheetVersion {
  id        String   @id @default(cuid())
  name      String? // 버전 이름 (예: "소스 v1", "2025-01-15 업로드")
  data      Json     @db.JsonB
  createdAt DateTime @default(now())

  workflowId String
  workflow   SchemaConverterWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  // 버전 체인 (Git 스타일)
  parentId String?
  parent   SourceSheetVersion?  @relation("SourceVersionHistory", fields: [parentId], references: [id], onDelete: SetNull)
  children SourceSheetVersion[] @relation("SourceVersionHistory")

  // 이 소스로 실행된 결과들
  appliedSheets AppliedConvertingSheet[]

  @@index([workflowId])
  @@index([parentId])
}

// 3. 타겟 시트 버전 (참조 스키마)
model TargetSheetVersion {
  id        String   @id @default(cuid())
  name      String? // 버전 이름
  data      Json     @db.JsonB
  createdAt DateTime @default(now())

  workflowId String
  workflow   SchemaConverterWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  // 버전 체인
  parentId String?
  parent   TargetSheetVersion?  @relation("TargetVersionHistory", fields: [parentId], references: [id], onDelete: SetNull)
  children TargetSheetVersion[] @relation("TargetVersionHistory")

  // 이 타겟을 참조한 실행들
  appliedSheets AppliedConvertingSheet[]

  @@index([workflowId])
  @@index([parentId])
}

// 4. 워크플로우 코드 (AI 생성 변환 로직)
model WorkflowCode {
  id          String   @id @default(cuid())
  name        String? // 코드 버전 이름
  code        String   @db.Text // JavaScript 코드
  mappingSuggestion String // 매핑 제안
  mappingScript Json  @db.JsonB
  createdAt   DateTime @default(now())

  workflowId String
  workflow   SchemaConverterWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  // 버전 체인
  parentId String?
  parent   WorkflowCode?  @relation("CodeVersionHistory", fields: [parentId], references: [id], onDelete: SetNull)
  children WorkflowCode[] @relation("CodeVersionHistory")

  // 이 코드로 실행된 결과들
  appliedSheets AppliedConvertingSheet[]

  @@index([workflowId])
  @@index([parentId])
}

// 5. 실행 결과 (변환된 최종 데이터)
model AppliedConvertingSheet {
  id         String   @id @default(cuid())
  resultData Json     @db.JsonB // 변환 결과
  createdAt  DateTime @default(now())

  // 어떤 조합으로 실행되었는지 추적
  workflowId String
  workflow   SchemaConverterWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  sourceSheetVersionId String
  sourceSheetVersion   SourceSheetVersion @relation(fields: [sourceSheetVersionId], references: [id], onDelete: Cascade)

  targetSheetVersionId String
  targetSheetVersion   TargetSheetVersion @relation(fields: [targetSheetVersionId], references: [id], onDelete: Cascade)

  workflowCodeId String
  workflowCode   WorkflowCode @relation(fields: [workflowCodeId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([sourceSheetVersionId])
  @@index([targetSheetVersionId])
  @@index([workflowCodeId])
  @@index([createdAt]) // 시간순 조회를 위해
}

// =================================
// Enums (변경 없음)
// =================================

enum SpreadSheetStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum ChatStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MessageType {
  TEXT
  ANALYSIS
  SUGGESTION
  ERROR
}
