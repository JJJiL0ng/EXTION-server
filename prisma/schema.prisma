generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  email        String?  @unique
  displayName  String
  photoURL     String?
  isGuest      Boolean  @default(false)
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @updatedAt
  preferences  Json? // UI 설정, 기본값 등
  statistics   Json? // 사용 통계

  // 관계
  spreadSheets SpreadSheet[]
  chats        Chat[]

  @@index([createdAt])
}

// 메인 스프레드시트 모델 (메타데이터 관리)
model SpreadSheet {
  id         String            @id @default(cuid())
  fileName   String
  fileSize   Int?              // 바이트 단위 (메타데이터로 유지, 실제 JSON 크기와 다를 수 있음)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  lastOpened DateTime          @default(now()) // 최근 열어본 시간
  version    Int               @default(1) // 파일 버전 (낙관적 잠금을 위한 핵심 필드)
  status     SpreadSheetStatus @default(ACTIVE)

  // 외래키
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatId String // 스프레드시트에 연결된 기본 채팅 ID (옵션)

  // 관계: 스프레드시트 데이터와 1:1 관계 유지
  data        SpreadSheetData?
  editHistory EditHistory[] // 편집 이력 모델은 유지하지만, 델타 레코드와의 직접적인 관계는 사라짐
  chats       Chat[]

  @@unique([userId, id]) // 사용자별 스프레드시트 ID 고유
  @@index([userId, updatedAt])
  @@index([userId, lastOpened])
}

// 스프레드시트 데이터 저장 (압축되지 않은 JSONB)
// 이제 전체 스프레드시트의 JSON 데이터를 압축 없이 그대로 저장합니다.
model SpreadSheetData {
  id            String   @id @default(cuid())
  spreadSheetId String   @unique
  data          Json     @db.JsonB // 압축되지 않은 전체 스프레드시트 JSON 데이터
  dataHash      String   // SHA-256 등 해시 (무결성 검증 및 변경 감지 용도)
  originalSize  Int      // JSON 데이터의 문자열 크기 (바이트)
  sheetCount    Int      @default(1) // 포함된 시트 수
  version       String   @default("18.1.4") // SpreadJS 버전 등 콘텐츠 버전
  savedAt       DateTime @default(now())

  // 관계
  spreadSheet SpreadSheet @relation(fields: [spreadSheetId], references: [id], onDelete: Cascade)

  @@index([dataHash])
  @@index([savedAt])
}

// 편집 히스토리 (단순화된 세션 관리)
// 개별 델타 기록이 사라지므로, 세션 단위의 변경 메타데이터만 남습니다.
model EditHistory {
  id            String     @id @default(cuid())
  spreadSheetId String
  sessionStart  DateTime   @default(now())
  sessionEnd    DateTime?  // null이면 진행중
  deltaCount    Int        @default(0) // 이 세션에서 발생한 델타의 총 개수 (델타 데이터는 직접 저장하지 않음)
  status        EditStatus @default(ACTIVE)

  // 메타데이터
  metadata Json? // 편집 통계, 브라우저 정보, 요약된 변경 내역 등

  // 관계
  spreadSheet SpreadSheet @relation(fields: [spreadSheetId], references: [id], onDelete: Cascade)

  @@index([spreadSheetId, sessionStart])
  @@index([status])
}


// 채팅 (AI 대화)
model Chat {
  id           String     @id @default(cuid())
  title        String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  messageCount Int        @default(0)
  status       ChatStatus @default(ACTIVE)

  // 스프레드시트 연결 (옵션)
  spreadSheetId String?
  spreadSheet   SpreadSheet? @relation(fields: [spreadSheetId], references: [id], onDelete: Cascade)

  // 사용자 연결
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 관계
  messages Message[]

  @@index([userId, status, updatedAt])
  @@index([spreadSheetId, updatedAt])
}

// 메시지
model Message {
  id        String      @id @default(cuid())
  content   String      @db.Text // 긴 텍스트 지원
  createdAt DateTime    @default(now())
  role      MessageRole
  type      MessageType @default(TEXT)

  // AI 분석 관련 메타데이터
  metadata Json? // 토큰 수, 처리 시간, 캐시 여부 등

  // 스프레드시트 컨텍스트 (메시지 작성 시점의 상태)
  sheetContext Json? // 관련 시트 정보, 셀 범위 등

  // 관계
  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
}


// Enum 정의
enum SpreadSheetStatus {
  ACTIVE // 활성 상태
  ARCHIVED // 보관됨
  DELETED // 삭제됨 (소프트 삭제)
}

enum EditStatus {
  ACTIVE // 편집 중
  COMPLETED // 완료됨
  ERROR // 오류 발생
}


enum ChatStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MessageType {
  TEXT // 일반 텍스트
  ANALYSIS // 데이터 분석 결과
  SUGGESTION // AI 제안
  ERROR // 오류 메시지
}

